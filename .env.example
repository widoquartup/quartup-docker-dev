# Configuración del entorno Docker para Quartup
# Copia este archivo a .env y ajusta los valores según tu configuración

# Configuración de puertos (único por desarrollador)
HTTP_PORT=8920
DEBUG_PORT=9920

# Información del desarrollador
USER_NAME=jmmunoz

# Rutas del proyecto
QUARTUP_PATH=../quartup
LOG_PATH=/home/jmmunoz/Desarrollo

# Configuración de Xdebug
XDEBUG_IDEKEY=jmmunoz
XDEBUG_REMOTE_HOST=127.0.0.1

# URLs y dominios
SERVER_NAME=devjmm.quartup.net
SERVER_ALIASES=jmm.localhost devjmm-avant.quartup.net devjmm-helio.quartup.net

# Rutas de logs
ERROR_LOG=/home/jmmunoz/Desarrollo/error.log
ACCESS_LOG=/home/jmmunoz/Desarrollo/access.log

# Configuración SSL
SSL_CERT_FILE=/var/www/SSLCert/server.bundle
SSL_KEY_FILE=/var/www/SSLCert/server.key 